{
  "title": "Task Tracker - Infrastructure & Kubernetes",
  "uid": "task-tracker-infra",
  "tags": ["task-tracker", "infrastructure", "kubernetes"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 3,
      "title": "Pod Restarts (15m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "increase(kube_pod_container_status_restarts_total{namespace=~\"task-tracker.*\"}[15m])", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "id": 4,
      "title": "HPA Current vs Max Replicas",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"task-tracker.*\"}", "legendFormat": "current - {{horizontalpodautoscaler}}" },
        { "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=~\"task-tracker.*\"}", "legendFormat": "max - {{horizontalpodautoscaler}}" }
      ]
    },
    {
      "id": 5,
      "title": "Pod Status",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "expr": "kube_pod_status_phase{namespace=~\"task-tracker.*\"} == 1", "legendFormat": "{{pod}} - {{phase}}" }
      ]
    },
    {
      "id": 6,
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        { "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100" }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 24 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total[5m])", "legendFormat": "RX - {{device}}" },
        { "expr": "rate(node_network_transmit_bytes_total[5m])", "legendFormat": "TX - {{device}}" }
      ]
    }
  ]
}
